generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Person {
  id       String   @id @default(cuid())
  name     String
  email    String   @unique
  address  Address?

  // Self-referencing many-to-many for "Friends"
  friends  Person[] @relation("PersonFriends")
  friendOf Person[] @relation("PersonFriends")
}

model Address {
  id       String @id @default(cuid())
  street   String
  city     String
  zip      String

  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  personId String @unique
}
